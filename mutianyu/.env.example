# ─── Mutianyu Wall Tickets — environment variables ──────────────────────────────
# Copy this file to .env and fill in real values. .env is gitignored — never
# commit real keys. On Vercel, set these SAME vars in
# Project → Settings → Environment Variables (the deployed functions read those,
# not this file). The local admin dashboard (npm run admin) reads this .env.

# Stripe — dashboard.stripe.com  (use sk_test_… / whsec_… while testing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend — resend.com/api-keys  (EMAIL_DOMAIN below must be verified in Resend)
RESEND_API_KEY=re_...

# Neon Postgres pooled connection string. Required for the booking database AND
# the local admin dashboard. Copy it from the Neon dashboard (the "-pooler" host).
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require

# Your site URL, no trailing slash — used for Stripe success/cancel redirects.
SITE_URL=https://mutianyu-tickets.com

# Email sending domain (verified in Resend). Mail is sent from bookings@<this>.
EMAIL_DOMAIN=mutianyu-tickets.com

# Where new-order notifications go — a mailbox you actually watch.
OPERATOR_EMAIL=your@email.com

# Secret that guards the daily /api/purge data-retention cron. Generate one with
# (PowerShell):  [Convert]::ToHexString((1..32|%{Get-Random -Max 256})).ToLower()
# and set the identical value here and in Vercel.
CRON_SECRET=

# Admin dashboard site config (used by admin/server.js multi-site support)
MUTIANYU_BRAND_NAME=Mutianyu Wall Tickets
MUTIANYU_BRAND_COLOR=#3A4A5C
MUTIANYU_SITE_URL=https://mutianyu-tickets.com
MUTIANYU_EMAIL_DOMAIN=mutianyu-tickets.com
MUTIANYU_SUPPORT_EMAIL=support@mutianyu-tickets.com

# Optional — port for the local admin dashboard (default 8787).
# ADMIN_PORT=8787
