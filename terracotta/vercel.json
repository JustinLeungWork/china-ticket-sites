{
  "functions": {
    "api/checkout.js": { "memory": 256 },
    "api/webhook.js":  { "memory": 256 },
    "api/enquiry.js":  { "memory": 256 },
    "api/purge.js":    { "memory": 256 }
  },
  "routes": [
    {
      "src": "/api/webhook",
      "dest": "/api/webhook.js",
      "headers": { "content-type": "application/json" }
    },
    {
      "src": "/api/checkout",
      "dest": "/api/checkout.js"
    },
    {
      "src": "/api/enquiry",
      "dest": "/api/enquiry.js"
    },
    {
      "src": "/api/purge",
      "dest": "/api/purge.js"
    }
  ],
  "crons": [
    { "path": "/api/purge", "schedule": "0 3 * * *" }
  ]
}
