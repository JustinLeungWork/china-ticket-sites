{
  "functions": {
    "api/checkout.js": { "memory": 256 },
    "api/webhook.js":  { "memory": 256 }
  },
  "routes": [
    {
      "src": "/api/webhook",
      "dest": "/api/webhook.js",
      "headers": { "content-type": "application/json" }
    },
    {
      "src": "/api/checkout",
      "dest": "/api/checkout.js"
    }
  ]
}
